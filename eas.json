{
  "cli": {
    "version": ">= 18.11.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "24.18.0"
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "environment": "development",
      "env": {
        "APP_VARIANT": "development"
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "channel": "preview",
      "environment": "preview",
      "env": {
        "APP_VARIANT": "preview"
      }
    },
    "production": {
      "extends": "base",
      "autoIncrement": true,
      "channel": "production",
      "environment": "production",
      "env": {
        "APP_VARIANT": "production"
      }
    },
    "apk-test": {
      "extends": "base",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_VARIANT": "preview"
      },
      "channel": "apk-test"
    },
    "production-apk": {
      "extends": "production",
      "environment": "production",
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "production"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -x lintVitalAnalyzeRelease"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6768416097"
      }
    }
  }
}
