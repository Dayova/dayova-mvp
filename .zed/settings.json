{
  "format_on_save": "on",
  "prettier": {
    "allowed": false,
  },
  "lsp": {
    "biome": {
      "settings": {
        "config_path": "biome.jsonc",
        "require_config_file": true,
      },
    },
  },
  "languages": {
    "CSS": {
      "formatter": {
        "language_server": {
          "name": "biome",
        },
      },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
      },
    },
    "JSON": {
      "formatter": {
        "language_server": {
          "name": "biome",
        },
      },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
      },
    },
    "JSONC": {
