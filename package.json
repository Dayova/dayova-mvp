{
	"name": "dayova-mvp",
	"version": "1.0.3",
	"main": "index.ts",
	"scripts": {
		"preinstall": "only-allow pnpm",
		"start": "run-p expo:start convex:dev",
		"android": "run-p expo:android convex:dev",
		"ios": "run-p expo:ios convex:dev",
		"convex:dev": "convex dev",
		"expo:start": "expo start",
		"expo:android": "expo run:android",
		"expo:ios": "expo run:ios",
		"lint": "run-s lint:biome lint:plugins",
		"lint:biome": "biome lint .",
		"lint:plugins": "eslint src convex index.ts",
		"lint:fix": "run-s lint:biome:fix lint:plugins:fix format:tailwind",
		"lint:biome:fix": "biome check . --write",
		"lint:plugins:fix": "eslint src convex index.ts --fix",
		"format": "run-s format:biome format:tailwind",
		"format:biome": "biome format . --write",
		"format:tailwind": "biome lint . --only=nursery/useSortedClasses --write",
		"format:check": "run-s format:biome:check format:tailwind:check",
		"format:biome:check": "biome format .",
		"format:tailwind:check": "biome lint . --only=nursery/useSortedClasses",
		"skills:validate": "run-s skills:validate:catalog skills:validate:matt skills:validate:expo",
		"skills:validate:catalog": "node scripts/validate-skills-catalog.mjs",
		"skills:validate:catalog:codex": "node scripts/validate-skills-catalog.mjs --check-codex-config",
		"skills:validate:expo": "node scripts/update-expo-skills.mjs --validate-current",
		"skills:validate:matt": "node scripts/update-matt-pocock-skills.mjs --validate-current",
		"skills:update:expo": "node scripts/update-expo-skills.mjs",
		"skills:update:matt": "node scripts/update-matt-pocock-skills.mjs",
		"test": "run-s test:unit test:ui",
		"test:unit": "run-s test:unit:vitest test:unit:metro-cache test:unit:skills",
		"test:unit:vitest": "vitest run",
		"test:unit:metro-cache": "node --test scripts/metro-cache-concurrency.test.cjs",
		"test:unit:skills": "node --test scripts/skills-catalog-validation.test.mjs",
		"test:ui": "jest --runInBand",
		"check": "run-s lint typecheck",
		"check:compiler": "pnpm dlx react-compiler-healthcheck@latest",
		"typecheck": "tsc --noEmit",
		"check:unused": "knip"
	},
	"dependencies": {
		"@ai-sdk/google-vertex": "^4.0.112",
		"@clerk/expo": "^3.5.2",
		"@expo/metro-runtime": "~56.0.17",
		"@expo/ui": "~56.0.18",
		"@gilhrpenner/convex-files-control": "^0.5.3",
		"@gorhom/bottom-sheet": "^5.2.14",
		"@hugeicons/core-free-icons": "^4.1.1",
		"@hugeicons/react-native": "^1.0.13",
		"@rn-primitives/portal": "^1.4.0",
		"@rn-primitives/slot": "^1.4.0",
		"@t3-oss/env-core": "^0.13.11",
		"ai": "^6.0.168",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"convex": "^1.41.0",
		"expo": "~56.0.16",
		"expo-application": "~56.0.3",
		"expo-constants": "^56.0.18",
		"expo-crypto": "^56.0.4",
		"expo-dev-client": "~56.0.20",
		"expo-device": "^56.0.4",
		"expo-document-picker": "~56.0.4",
		"expo-file-system": "~56.0.8",
		"expo-font": "~56.0.7",
		"expo-image-picker": "~56.0.18",
		"expo-linear-gradient": "~56.0.4",
		"expo-linking": "^56.0.14",
		"expo-localization": "~56.0.6",
		"expo-notifications": "~56.0.18",
		"expo-router": "^56.2.11",
		"expo-secure-store": "~56.0.4",
		"expo-splash-screen": "~56.0.10",
		"expo-status-bar": "~56.0.4",
		"expo-system-ui": "~56.0.5",
		"expo-updates": "~56.0.19",
		"nativewind": "^4.2.3",
		"officeparser": "^6.1.0",
		"posthog-react-native": "^4.50.0",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"react-native": "0.85.3",
		"react-native-css-interop": "^0.2.3",
		"react-native-gesture-handler": "^2.31.2",
		"react-native-keyboard-controller": "1.21.6",
		"react-native-nitro-modules": "^0.35.10",
		"react-native-nitro-speech": "0.4.8",
		"react-native-reanimated": "^4.3.1",
		"react-native-safe-area-context": "^5.7.0",
		"react-native-screens": "^4.25.2",
		"react-native-svg": "^15.15.4",
		"react-native-worklets": "0.8.3",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^3.4.1",
		"tailwindcss-animate": "^1.0.7",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@babel/plugin-transform-react-jsx": "^7.28.6",
		"@biomejs/biome": "^2.4.14",
		"@convex-dev/eslint-plugin": "^2.0.0",
		"@edge-runtime/vm": "^5.0.0",
		"@expo/metro-config": "56.0.17",
		"@jest/globals": "29.7.0",
		"@react-native/jest-preset": "0.85.3",
		"@testing-library/react-native": "^14.0.1",
		"@types/jest": "29.5.14",
		"@types/node": "^25.6.0",
		"@types/react": "~19.2.14",
		"babel-preset-expo": "~56.0.10",
		"convex-test": "^0.0.53",
		"eslint": "^10.3.0",
		"eslint-plugin-react-hooks": "^7.1.1",
		"jest": "~29.7.0",
		"jest-expo": "~56.0.5",
		"knip": "^6.13.1",
		"npm-run-all2": "^8.0.4",
		"only-allow": "^1.2.2",
		"react-native-svg-transformer": "^1.5.3",
		"skills": "1.5.19",
		"smol-toml": "1.7.0",
		"test-renderer": "1.2.0",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.59.1",
		"vite": "^8.0.14",
		"vitest": "^4.1.7",
		"yaml": "^2.9.0"
	},
	"private": true,
	"engines": {
		"node": ">=22 <24"
	},
	"packageManager": "pnpm@10.25.0"
}
