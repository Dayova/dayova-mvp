# Dayova environment variables
#
# There are two different runtimes:
# 1. Expo / React Native app runtime
#    Convex CLI writes the Convex public app URLs locally when you run
#    `npx convex dev`, `pnpm convex:dev`, or similar.
#    Do not manually maintain those local Convex URL values unless the CLI is
#    not available in that environment.
#
# 2. Convex backend runtime
#    Set these with `npx convex env set NAME value` or in the Convex dashboard.
#    Do NOT expose these as `EXPO_PUBLIC_*` values.


# -----------------------------------------------------------------------------
# Convex-managed app envs
#
# Local dev:
#   These are automatically generated/updated by Convex CLI.
#   Run `pnpm convex:dev` or `npx convex dev`.
#
# EAS / production:
#   If your build process runs Convex CLI before bundling, it can also provide
#   these values there. If it does not, set EXPO_PUBLIC_CONVEX_URL and
#   EXPO_PUBLIC_CONVEX_SITE_URL in EAS/CI for the target deployment.
#
# Do not set CONVEX_DEPLOYMENT in EAS unless you intentionally run Convex CLI
# during the build/deploy process.
# -----------------------------------------------------------------------------

# Public Convex deployment URL used by the mobile app.
# Usually generated by Convex CLI.
# Example: https://your-deployment.convex.cloud
EXPO_PUBLIC_CONVEX_URL=

# Public Convex site URL, only needed if the app calls Convex HTTP endpoints.
# Usually generated by Convex CLI.
# Example: https://your-deployment.convex.site
EXPO_PUBLIC_CONVEX_SITE_URL=

# Convex deployment selector.
# Generated/managed by Convex CLI.
# Example: dev:your-deployment-name
CONVEX_DEPLOYMENT=


# -----------------------------------------------------------------------------
# Clerk auth envs
#
# Expo / React Native app runtime:
#   EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY is safe to expose to the mobile app.
#   Set it in local .env files and in EAS/CI for native builds.
#   Example: pk_test_...
#
# Convex backend runtime:
#   CLERK_JWT_ISSUER_DOMAIN is the Clerk Frontend API URL / issuer domain used
#   by Convex JWT validation. Set it in Convex, not as EXPO_PUBLIC_*.
#   Example: https://warm-parrot-13.clerk.accounts.dev
#
# Clerk secret key:
#   Not used by this app right now. Do not add CLERK_SECRET_KEY unless backend
#   code starts calling Clerk server APIs directly.
#
# Commands:
#   npx convex env set CLERK_JWT_ISSUER_DOMAIN "https://..."
# -----------------------------------------------------------------------------

EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

CLERK_JWT_ISSUER_DOMAIN=


# -----------------------------------------------------------------------------
# Convex backend envs: Lernplan file storage
# Set in Convex, not in Expo/EAS public envs.
#
# Default and recommended provider is Cloudflare R2 via convex-files-control.
# FILE_STORAGE_PROVIDER may be:
#   r2      Recommended. Uses Cloudflare R2.
#   convex  Fallback/dev option. Uses Convex file storage instead.
#
# Commands:
#   npx convex env set FILE_STORAGE_PROVIDER "r2"
#   npx convex env set R2_ACCOUNT_ID "..."
#   npx convex env set R2_ACCESS_KEY_ID "..."
#   npx convex env set R2_SECRET_ACCESS_KEY "..."
#   npx convex env set R2_BUCKET_NAME "..."
#   npx convex env set R2_JURISDICTION "eu"
#
# Cloudflare R2 token requirements:
#   The S3-compatible access key must have Object Read & Write access to the
#   exact bucket named in R2_BUCKET_NAME. Read-only keys can still generate a
#   signed URL, but R2 will reject the mobile PUT upload with 403 AccessDenied.
#   Buckets created in a jurisdiction such as EU must also set
#   R2_JURISDICTION so signed URLs use the correct endpoint, for example:
#   https://<ACCOUNT_ID>.eu.r2.cloudflarestorage.com
# -----------------------------------------------------------------------------

FILE_STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_JURISDICTION=


# -----------------------------------------------------------------------------
# Convex backend envs: Lernplan AI
# Set in Convex, not in Expo/EAS public envs.
#
# Option A: Vertex AI Express Mode
#   Set GOOGLE_VERTEX_API_KEY.
#
# Option B: Google Cloud Vertex project auth
#   Set GOOGLE_VERTEX_PROJECT and optionally GOOGLE_VERTEX_LOCATION.
#
# The code currently uses model `gemini-3-flash-preview`.
# Default location is `global`, which is the safest default for Gemini 3 Flash
# availability. Only override it if you intentionally use a supported regional
# or multi-region endpoint for your chosen model.
#
# Commands:
#   npx convex env set GOOGLE_VERTEX_API_KEY "..."
#   npx convex env set GOOGLE_VERTEX_PROJECT "..."
#   npx convex env set GOOGLE_VERTEX_LOCATION "global"
# -----------------------------------------------------------------------------

GOOGLE_VERTEX_API_KEY=
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=global
